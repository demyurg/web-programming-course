{
  "name": "quiz-backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:studio": "npx prisma studio",
    "test:unit": "vitest run --dir src --testNamePattern unit",
    "test:feature": "vitest run --dir src --testNamePattern feature",
    "test": "vitest run --dir src",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/client": "^6.2.0",
    "dotenv": "^17.3.1",
    "hono": "^4.11.10",
    "prisma": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^4.0.18",
    "prismock": "^1.35.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  }
}
