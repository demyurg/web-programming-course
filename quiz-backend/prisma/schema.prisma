// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  githubId  String    @unique
  role      String    @default("student") // "student" или "admin"
  sessions  Session[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Question {
  id             String       @id @default(cuid())
  text           String
  type           String       // "multiple-select", "essay"
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])
  correctAnswer  Json?        // Для multiple-select: ["A","B","C"]
  points         Int          @default(1)
  answers        Answer[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Индексы для оптимизации
  @@index([type])
  @@index([categoryId])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  status      String    @default("in_progress") // "in_progress", "completed", "expired"
  score       Float?
  startedAt   DateTime  @default(now())
  expiresAt   DateTime
  completedAt DateTime?
  answers     Answer[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Индексы для оптимизации
  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([expiresAt])
}

model Answer {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  userAnswer Json?     // Может быть массивом для multiple-select или строкой для essay
  score      Float?   // null если ещё не проверен (essay)
  isCorrect  Boolean? // для автопроверки
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Уникальность: один ответ на вопрос в сессии
  @@unique([sessionId, questionId])
  
  // Индексы для оптимизации
  @@index([sessionId])
  @@index([questionId])
  @@index([score]) // для поиска непроверенных essay
}