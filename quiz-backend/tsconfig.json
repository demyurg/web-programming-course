{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node", // Используем "node" вместо "bundler"
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "verbatimModuleSyntax": false // Отключаем строгий режим импортов
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}